generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/* ===================== AUTH ===================== */

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpCode {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  code      String
  purpose   String   @default("VERIFY_EMAIL")
  expiresAt DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, purpose])
}

/* ===================== USER ===================== */

model User {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  password      String?
  /// @deprecated Prefer countryName + countryCode; kept for legacy receipts / data
  country       String?
  countryCode   String?
  countryName   String?
  region        String?
  city          String?
  phone         String?
  birthdate              String?
  gender                 String?
  profileCompletionSeen  Boolean  @default(false)
  role          Role     @default(DONOR)
  preferredLang String? // locale from first donation (ar, en, fr) for emails/SMS

  /// Section keys for Role.STAFF — see lib/dashboard/permissions.ts; ignored for ADMIN
  dashboardPermissions String[] @default([])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts     Account[]
  sessions     Session[]
  donations    Donation[]
  subscriptions Subscription[]
  comments     Comment[]
  cartItems    CartItem[]
  messages     Message[]
  creditCards  CreditCard[]
}

/* ===================== CREDIT CARDS ===================== */

model CreditCard {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  cardNumber     String   // AES-256 encrypted full card number
  cardType       String   // "visa" | "mastercard" | "amex" | "troy" | "unknown"
  expiryDate     String   // MM/YY stored as-is
  cvc            String   // bcrypt-hashed
  cardholderName String?

  isDefault      Boolean  @default(false)
  nickname       String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

/* ===================== AUDIT LOG (dashboard activity) ===================== */

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt  DateTime @default(now())
  actorId    String?  @db.ObjectId
  actorName  String?
  actorRole  String
  action     String
  messageAr  String
  messageEn  String?
  entityType String?
  entityId   String?
  metadata   Json?
  /// TEAM: actions by ADMIN/STAFF — DONOR: actions by donors (e.g. donations, profile)
  stream     String
}

/* ===================== CONTACT MESSAGES ===================== */

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  subject   MessageSubject? @default(GENERAL)
  body      String   @db.String
  locale    String   // ar, en, fr - language when sent
  userId    String?  @db.ObjectId // optional: guest can send without account
  guestName String?
  guestEmail String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum MessageSubject {
  COMPLAINT
  DONATION_ISSUE
  CAMPAIGN_SUPPORT
  PARTNERSHIP
  VOLUNTEERING
  GENERAL
}

enum Role {
  ADMIN
  DONOR
  STAFF
}

/* ===================== USER BADGES (GROUPS) ===================== */
// Badges are computed from criteria; no direct User-Badge relation stored.
// Criteria types: TOTAL_LAST_N_MONTHS, ANY_SPAN_N_MONTHS, MONTHLY_ACTIVE_RANGE, TOTAL_LIFETIME, DONATION_COUNT_MIN

model Badge {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   // default name (e.g. Arabic)
  color     String   @default("#3b82f6") // hex
  criteria  Json     // { type, amountMinUSD?, amountMaxUSD?, months?, count? }
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations BadgeTranslation[]
}

model BadgeTranslation {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  badgeId String @db.ObjectId
  locale String // ar, en, fr
  name   String

  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([badgeId, locale])
}

/* ===================== CATEGORY ===================== */

model Category {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  // Arabic (default)
  name          String   @unique
  description   String?

  /// URL slug for human-friendly category links (unique across categories)
  slug          String?  @unique

  image         String?
  icon          String?
  order         Int?
  currentAmount Float    @default(0)

  campaigns              Campaign[]
  donationItems          DonationCategoryItem[]
  subscriptionCategoryItems SubscriptionCategoryItem[]
  translations           CategoryTranslation[]
}

model CategoryTranslation {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  categoryId String   @db.ObjectId
  locale     String   // en, fr, ...

  name        String
  description String?

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
}

/* ===================== HERO SLIDES ===================== */

model Slide {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String   // Arabic default
  description String?
  image       String?
  showButton  Boolean  @default(true)
  buttonText  String?
  buttonLink  String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  translations SlideTranslation[]
}

model SlideTranslation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slideId     String   @db.ObjectId
  locale      String
  title       String
  description String?
  buttonText  String?
  slide       Slide    @relation(fields: [slideId], references: [id], onDelete: Cascade)
  @@unique([slideId, locale])
}

/* ===================== CAMPAIGN ===================== */

model Campaign {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  // Arabic (default)
  title         String
  description   String

  /// URL slug for human-friendly campaign links (unique across campaigns)
  slug          String?  @unique

  targetAmount  Float
  currentAmount Float   @default(0)
  images        String[]
  videoUrl      String?
  isActive         Boolean @default(true)
  priority         Int?
  /// Priority within the campaign's category — controls ordering when listing the category's campaigns
  categoryPriority Int?

  /// { "amounts": number[], "byCurrency"?: Record<string, number[]> } — quick-pick donation amounts; omit/null uses app defaults
  suggestedDonations Json?

  /// FIXED = show goal & progress bar; OPEN = open-ended (no fixed target UI)
  goalType              String   @default("FIXED")
  /// AMOUNT = donor enters amount; SHARES = سهوم (share price × number of shares)
  fundraisingMode       String   @default("AMOUNT")
  /// Price of one share in USD when fundraisingMode is SHARES
  sharePriceUSD         Float?
  /// { "counts": number[] } — quick-pick share counts for سهوم campaigns
  suggestedShareCounts  Json?

  categoryId    String   @db.ObjectId
  category      Category @relation(fields: [categoryId], references: [id])

  updates           Update[]
  comments          Comment[]
  cartItems         CartItem[]
  donations         DonationItem[]
  subscriptionItems SubscriptionItem[]
  translations      CampaignTranslation[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CampaignTranslation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId  String   @db.ObjectId
  locale      String   // en, fr, ...

  title       String
  description String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, locale])
}

/* ===================== CAMPAIGN UPDATES ===================== */

model Update {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  // Arabic
  title       String
  description String

  image       String?
  videoUrl    String?

  campaignId  String   @db.ObjectId
  campaign    Campaign @relation(fields: [campaignId], references: [id])

  translations UpdateTranslation[]

  createdAt   DateTime @default(now())
}

model UpdateTranslation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  updateId  String   @db.ObjectId
  locale    String

  title       String
  description String

  update Update @relation(fields: [updateId], references: [id], onDelete: Cascade)

  @@unique([updateId, locale])
}

/* ===================== DONATIONS ===================== */

model Referral {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  code             String   @unique // e.g. "ahmed", "tiktok1"
  name             String?  // optional label for dashboard
  cookieExpiryDays Int      @default(30) // 0 = unlimited (cookie lasts ~10 years)
  createdAt        DateTime @default(now())

  donations     Donation[]
  subscriptions Subscription[]
}

model Donation {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  amount     Float
  amountUSD  Float?
  currency   String   @default("USD")
  teamSupport Float   @default(0)
  coverFees  Boolean  @default(false)
  fees       Float    @default(0)
  totalAmount Float

  status     DonationStatus @default(PAID)
  locale     String?

  // Payment provider tracking (PayFor Sanal POS)
  provider               String? // e.g. "PAYFOR"
  providerOrderId        String? // PayFor OrderId (we use donation id by default)
  providerTxnType        String? // e.g. "Auth"
  providerProcReturnCode String?
  providerTxnResult      String? // "Success" / "Failed"
  providerAuthCode       String?
  providerHostRefNum     String?
  providerErrorMessage   String?
  providerRaw            Json?

  donorId        String    @db.ObjectId
  donor          User      @relation(fields: [donorId], references: [id])
  referralId     String?   @db.ObjectId
  referral       Referral? @relation(fields: [referralId], references: [id])

  subscriptionId String?       @db.ObjectId
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  comment       String?
  paymentMethod PaymentMethod
  cardDetails   CardDetails?

  createdAt DateTime @default(now())
  paidAt    DateTime?

  items         DonationItem[]
  categoryItems DonationCategoryItem[]
  comments      Comment[]
}

model Subscription {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  status     SubscriptionStatus @default(ACTIVE)

  amount       Float
  amountUSD    Float?
  currency     String   @default("USD")
  teamSupport  Float    @default(0)
  coverFees    Boolean  @default(false)
  paymentMethod PaymentMethod
  cardDetails  CardDetails?

  // PayFor recurring support (requires bank-provided token/reference transaction model)
  payforToken     String?
  payforMaskedPan String?
  payforExpiry    String? // MMYY (if bank requires it alongside token)

  donorId    String   @db.ObjectId
  donor      User     @relation(fields: [donorId], references: [id])
  referralId String?  @db.ObjectId
  referral   Referral? @relation(fields: [referralId], references: [id])

  nextBillingDate DateTime?
  lastBillingDate DateTime?

  createdAt DateTime @default(now())

  items         SubscriptionItem[]
  categoryItems SubscriptionCategoryItem[]
  donations     Donation[]
}

model SubscriptionItem {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  subscriptionId String   @db.ObjectId
  campaignId     String   @db.ObjectId

  amount    Float
  amountUSD Float?

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  campaign     Campaign     @relation(fields: [campaignId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubscriptionCategoryItem {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  subscriptionId String   @db.ObjectId
  categoryId     String   @db.ObjectId

  amount    Float
  amountUSD Float?

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  category     Category     @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DonationItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  donationId String   @db.ObjectId
  campaignId String   @db.ObjectId

  amount     Float
  amountUSD  Float?
  /// When set, line item was a سهوم (shares) purchase
  shareCount Int?

  donation Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DonationCategoryItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  donationId String   @db.ObjectId
  categoryId String   @db.ObjectId

  amount     Float
  amountUSD  Float?

  donation Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  category  Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum DonationStatus {
  PAID
  FAILED
}

enum PaymentMethod {
  CARD
  PAYPAL
}

type CardDetails {
  cardNumber     String
  expiryDate     String
  cvv            String
  cardholderName String
}

/* ===================== COMMENTS & CART ===================== */

model Comment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  text       String

  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])

  donationId String?  @db.ObjectId
  donation   Donation? @relation(fields: [donationId], references: [id])

  campaignId String   @db.ObjectId
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  createdAt  DateTime @default(now())
}

model CartItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId String   @db.ObjectId
  userId     String   @db.ObjectId

  amount     Float
  amountUSD  Float?
  currency   String   @default("USD")
  /// Optional: number of سهوم shares for this line (display / receipt)
  shareCount Int?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/* ===================== POSTS ===================== */

model PostCategory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  // Arabic
  name      String   @unique
  title     String?
  description String?
  image     String?

  /// URL slug for blog category links (unique across post categories)
  slug      String?  @unique

  posts       Post[]
  translations PostCategoryTranslation[]

  createdAt DateTime @default(now())
}

model PostCategoryTranslation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  categoryId  String   @db.ObjectId
  locale      String

  name        String
  title       String?
  description String?
  image       String?

  category PostCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
}

model Post {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  // Arabic
  title     String?
  description String?
  content   String?
  image     String?

  /// URL slug for blog post links (unique across posts)
  slug      String?  @unique

  published Boolean @default(false)

  categoryId String? @db.ObjectId
  category   PostCategory? @relation(fields: [categoryId], references: [id])

  /// Up to 3 related campaigns (enforced in API / UI)
  campaignIds String[] @default([]) @db.ObjectId

  translations PostTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostTranslation {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  postId  String   @db.ObjectId
  locale  String

  title       String?
  description String?
  content     String?
  image       String?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
}

model LiveDonationTicker {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  
  isActive  Boolean  @default(true)
  
  // Donor names pool (will be randomly selected)
  donorNames String[] @default([])
  
  // Campaign names by locale
  // campaignNamesAr String[] @default([])
  // campaignNamesEn String[] @default([])
  // campaignNamesFr String[] @default([])
  
  // Amount ranges with probabilities
  amountRanges AmountRange[]
  
  // Display timing
  minIntervalSeconds Int @default(3)  // Minimum seconds between donations
  maxIntervalSeconds Int @default(8)  // Maximum seconds between donations
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

type AmountRange {
  minAmount    Float
  maxAmount    Float
  probability  Float  // Weight for this range (e.g., 70 for high, 20 for medium, 10 for low)
  label        String // e.g., "high", "medium", "low"
}

/* ===================== TRACKING PIXELS (dashboard configurable) ===================== */
model TrackingSettings {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  facebookPixelId         String?
  facebookAccessToken     String?  // Meta CAPI token (never exposed to client)
  gaMeasurementId         String?  // Google Analytics 4: G-XXXXXXXXXX
  tiktokPixelId           String?
  tiktokAccessToken       String?  // TikTok Events API token (never exposed to client)
  googleAdsConversionId   String?  // AW-XXXXXXXXX (never exposed to client — used server-side for EC)
  googleAdsConversionLabel String? // Conversion label (e.g. AbCdEfGh1234)
  xPixelId                String?  // X (Twitter) Pixel ID
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
